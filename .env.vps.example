## VPS environment for qcontrol.
## Copy to .env on the VPS, fill in real values, then:
##   docker compose -f docker-compose.yml -f docker-compose.vps.yml up -d --build

# A long random string. Treat like a root password — anyone with this
# can restart any container on this VPS.
QCONTROL_TOKEN=

# Port qcontrol binds to on 127.0.0.1. Defaults to 8089 (next free in the
# shared-reverse-proxy port table). Change only if 8089 is already taken.
QCONTROL_PORT=8089
